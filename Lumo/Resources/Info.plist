<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Orchet</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>0.1.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
		<key>NSExceptionDomains</key>
		<dict>
			<key>localhost</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<true/>
				<key>NSIncludesSubdomains</key>
				<true/>
			</dict>
		</dict>
	</dict>
	<key>LumoAPIBase</key>
	<string>https://lumo-super-agent.vercel.app</string>
	<!-- Gateway base URL for the P2H iOS migration. Empty default
	     means migrated services fall back to LumoAPIBase (apps/web
	     BFF proxies). Ops populates this string when the gateway
	     deployment is reachable for the iOS build environment. -->
	<key>OrchetGatewayBase</key>
	<string>https://api.orchet.ai</string>
	<key>LumoSupabaseURLScheme</key>
	<string>$(LUMO_SUPABASE_URL_SCHEME)</string>
	<key>LumoSupabaseURLHost</key>
	<string>$(LUMO_SUPABASE_URL_HOST)</string>
	<key>LumoSupabaseAnonKey</key>
	<string>$(LUMO_SUPABASE_ANON_KEY)</string>
	<key>LumoStripePublishableKey</key>
	<string>$(LUMO_STRIPE_PUBLISHABLE_KEY_TEST)</string>
	<key>LumoStripeMerchantID</key>
	<string>$(LUMO_STRIPE_MERCHANT_ID)</string>
	<key>LumoAPNsUseSandbox</key>
	<string>$(LUMO_APNS_USE_SANDBOX)</string>
	<!--
	  ORCHET-IOS-PARITY-1: streaming voice path.
	  - OrchetVoiceMode: "batch" (default — legacy push-to-talk
	                     through Deepgram /stt + /tts) or
	                     "streaming" (Daily WebRTC against the
	                     orchet-voice Fly service).
	  - OrchetVoiceBase: voice service base URL. Defaults to
	                     orchet-voice.fly.dev; only override for a
	                     custom branch deployment.
	-->
	<key>OrchetVoiceMode</key>
	<string>$(ORCHET_VOICE_MODE)</string>
	<key>OrchetVoiceBase</key>
	<string>$(ORCHET_VOICE_BASE)</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Orchet uses your microphone so you can talk to your assistant. Your voice is processed on-device for transcription; nothing is recorded or stored.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>Orchet uses on-device speech recognition to turn your voice into the messages you send. Transcripts are processed locally; only the resulting text is sent to Orchet.</string>
	<key>NSUserNotificationsUsageDescription</key>
	<string>Orchet notifies you about trip updates, proactive suggestions, and payment receipts. You can customize categories in Settings.</string>
	<key>NSCalendarsFullAccessUsageDescription</key>
	<string>Orchet uses your calendar to proactively remind you and to learn what you're doing day-to-day. You control this in Settings → Memory Sources, where you can also clear what Orchet has learned at any time.</string>
	<key>NSRemindersFullAccessUsageDescription</key>
	<string>Orchet uses your reminders to learn your routines and surface them at the right moment. Toggle this off in Settings → Memory Sources, or use the in-app "Forget" button to clear what Orchet has remembered.</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
		<string>fetch</string>
		<string>processing</string>
		<!--
		  audio: keep the Daily WebRTC call alive while the screen
		  is locked or the app is backgrounded (ORCHET-IOS-PARITY-1).
		-->
		<string>audio</string>
	</array>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>com.lumo.rentals.ios.proactive-refresh</string>
	</array>
	<!--
	  AUTH-OAUTH-1b URL schemes:
	  - lumo://auth/callback        — legacy Supabase OAuth callback. Kept
	                                   alongside `orchet` for one release
	                                   per REBRAND-LUMO-TO-ORCHET-1 so
	                                   in-flight OAuth sessions still
	                                   resume cleanly after the rename.
	  - orchet://auth/callback      — new Supabase OAuth callback target.
	                                   ASWebAuthenticationSession matches
	                                   on either scheme and resumes the
	                                   session.
	  - com.googleusercontent.apps.971943870024-97g5erdstdg2ue3ho4skr4126e4sovkr
	                                — Google Sign-In reversed-client-ID,
	                                   registered for compatibility with
	                                   the Google identity SDK pattern
	                                   even though we use the Supabase
	                                   web flow rather than the GoogleSignIn
	                                   SDK (kept the bundle clean per brief).
	-->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>com.lumo.rentals.ios.auth</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>orchet</string>
				<string>lumo</string>
			</array>
		</dict>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>com.lumo.rentals.ios.googleoauth</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.971943870024-97g5erdstdg2ue3ho4skr4126e4sovkr</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
